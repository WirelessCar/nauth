{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)",
    ":gitSignOff",
    "customManagers:biomeVersions"
  ],
  "timezone": "Europe/Stockholm",
  "labels": ["dependencies"],
  "schedule": ["before 6am on monday"],
  "rangeStrategy": "bump",
  "osvVulnerabilityAlerts": true,
  "asdf": {
    "enabled": false
  },
  "lockFileMaintenance": {
    "enabled": false
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "addLabels": ["security"],
    "vulnerabilityFixStrategy": "lowest"
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true,
      "addLabels": ["major"]
    },
    {
      "description": "Skip routine patch updates; vulnerability fixes are handled separately.",
      "matchUpdateTypes": ["patch"],
      "enabled": false
    },
    {
      "description": "Group routine minor dependency updates into one weekly PR",
      "matchUpdateTypes": ["minor"],
      "matchPackageNames": ["*"],
      "groupName": "minor dependency updates",
      "groupSlug": "minor-dependencies"
    },
    {
      "description": "Keep go.mod's Go directive as the minimum compatibility version",
      "matchManagers": ["gomod"],
      "matchDepNames": ["go"],
      "matchDepTypes": ["golang"],
      "rangeStrategy": "replace"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.tool-versions$/"],
      "matchStrings": ["(?:^|\\n)bun\\s+(?<currentValue>\\S+)"],
      "depNameTemplate": "bun",
      "datasourceTemplate": "npm",
      "versioningTemplate": "npm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.tool-versions$/"],
      "matchStrings": ["(?:^|\\n)go:sigs\\.k8s\\.io/controller-tools/cmd/controller-gen\\s+(?<currentValue>\\S+)"],
      "depNameTemplate": "sigs.k8s.io/controller-tools",
      "datasourceTemplate": "go",
      "versioningTemplate": "semver-coerced"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.tool-versions$/"],
      "matchStrings": ["(?:^|\\n)golangci-lint\\s+(?<currentValue>\\S+)"],
      "depNameTemplate": "github.com/golangci/golangci-lint/v2",
      "datasourceTemplate": "go",
      "versioningTemplate": "semver-coerced"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.tool-versions$/"],
      "matchStrings": ["(?:^|\\n)kustomize\\s+(?<currentValue>\\S+)"],
      "depNameTemplate": "sigs.k8s.io/kustomize/kustomize/v5",
      "datasourceTemplate": "go",
      "versioningTemplate": "semver-coerced"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^mise\\.toml$/"],
      "matchStrings": ["NATS_VERSION\\s*=\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "nats",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^mise\\.toml$/"],
      "matchStrings": ["NACK_VERSION\\s*=\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "natsio/jetstream-controller",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^mise\\.toml$/"],
      "matchStrings": ["NATS_RELOADER_VERSION\\s*=\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "natsio/nats-server-config-reloader",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^mise\\.toml$/"],
      "matchStrings": ["NATS_BOX_VERSION\\s*=\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "natsio/nats-box",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ]
}

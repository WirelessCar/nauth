{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)",
    "customManagers:biomeVersions"
  ],
  "timezone": "Europe/Stockholm",
  "labels": ["dependencies"],
  "schedule": ["before 6am on monday"],
  "rangeStrategy": "bump",
  "asdf": {
    "enabled": false
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"]
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true,
      "addLabels": ["major"]
    },
    {
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Go dependencies"
    },
    {
      "matchManagers": ["bun"],
      "matchFileNames": ["www/**"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "www dependencies"
    },
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "GitHub Actions"
    },
    {
      "matchManagers": ["helmv3"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "Helm chart dependencies"
    },
    {
      "matchManagers": ["mise"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "mise tools"
    },
    {
      "matchFileNames": [".tool-versions"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "local tool versions"
    },
    {
      "matchFileNames": ["mise.toml"],
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "local NATS image versions"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.tool-versions$/"],
      "matchStrings": ["(?:^|\\n)bun\\s+(?<currentValue>\\S+)"],
      "depNameTemplate": "bun",
      "datasourceTemplate": "npm",
      "versioningTemplate": "npm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.tool-versions$/"],
      "matchStrings": ["(?:^|\\n)controller-gen\\s+(?<currentValue>\\S+)"],
      "depNameTemplate": "sigs.k8s.io/controller-tools",
      "datasourceTemplate": "go",
      "versioningTemplate": "semver-coerced"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.tool-versions$/"],
      "matchStrings": ["(?:^|\\n)golangci-lint\\s+(?<currentValue>\\S+)"],
      "depNameTemplate": "github.com/golangci/golangci-lint/v2",
      "datasourceTemplate": "go",
      "versioningTemplate": "semver-coerced"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.tool-versions$/"],
      "matchStrings": ["(?:^|\\n)kustomize\\s+(?<currentValue>\\S+)"],
      "depNameTemplate": "sigs.k8s.io/kustomize/kustomize/v5",
      "datasourceTemplate": "go",
      "versioningTemplate": "semver-coerced"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^mise\\.toml$/"],
      "matchStrings": ["NATS_VERSION\\s*=\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "nats",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^mise\\.toml$/"],
      "matchStrings": ["NACK_VERSION\\s*=\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "natsio/jetstream-controller",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^mise\\.toml$/"],
      "matchStrings": ["NATS_RELOADER_VERSION\\s*=\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "natsio/nats-server-config-reloader",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^mise\\.toml$/"],
      "matchStrings": ["NATS_BOX_VERSION\\s*=\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "natsio/nats-box",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ]
}
